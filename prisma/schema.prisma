generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaListStatus {
  WATCHING
  COMPLETED
  PENDING
  PLAN_TO_WATCH
  DROPPED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  avatarUrl    String?
  bio          String?
  createdAt    DateTime       @default(now())
  mediaLists   MediaList[]
  reviews      Review[]
  customLists  CustomList[]
  followers    Connection[]   @relation("following")
  following    Connection[]   @relation("follower")
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model MediaList {
  id         String          @id @default(cuid())
  userId     String
  tmdbId     Int
  mediaType  String
  title      String
  posterPath String?
  status     MediaListStatus
  isFavorite Boolean         @default(false)
  rating     Int?
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([userId, status])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType String
  title     String
  content   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([tmdbId])
}

model CustomList {
  id        String           @id @default(cuid())
  userId    String
  name      String
  isPublic  Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CustomListItem[]

  @@index([userId])
}

model CustomListItem {
  id         String     @id @default(cuid())
  listId     String
  tmdbId     Int
  mediaType  String
  title      String
  posterPath String?
  list       CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, tmdbId])
  @@index([listId])
}
